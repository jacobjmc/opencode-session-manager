{
  "name": "opencode-session-manager",
  "version": "0.1.1",
  "description": "OpenCode plugin with session listing, reading, search, and metadata tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "session",
    "agent"
  ],
  "author": "Jacob",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobjmc/opencode-session-manager.git"
  },
  "bugs": {
    "url": "https://github.com/jacobjmc/opencode-session-manager/issues"
  },
  "homepage": "https://github.com/jacobjmc/opencode-session-manager#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "opencode": {
    "type": "plugin",
    "tools": [
      "session_list",
      "session_read",
      "session_search",
      "session_info"
    ]
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/sdk": "^1.2.15",
    "@types/bun": "^1.3.5",
    "@types/node": "^22.13.9",
    "typescript": "^5.8.2"
  }
}
